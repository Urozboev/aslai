# ── Supabase ────────────────────────────────────────────────────
# Supabase Dashboard → Project Settings → API bo'limidan oling
VITE_SUPABASE_URL=          # Project URL (masalan: https://xxxxxxxx.supabase.co)
VITE_SUPABASE_ANON_KEY=     # anon / public API key

# ── Gemini AI (ixtiyoriy, lekin AI funksiyalari uchun kerak) ─────
# Google AI Studio (https://aistudio.google.com/apikey) → Get API key
# ⚠️ Bu kalit brauzer bundle'iga kiradi va ommaga ko'rinadi.
#    AI Studio'da kalitga HTTP referrer cheklovini (faqat domeningiz) qo'ying.
# Kalit bo'lmasa — AI funksiyalari evristik (oddiy) rejimga qaytadi.
VITE_GEMINI_API_KEY=
VITE_GEMINI_MODEL=          # ixtiyoriy, standart: gemini-2.5-flash
